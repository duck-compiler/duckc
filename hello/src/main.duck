use std::col::ArrayList;
use std::io::{println};

client fn x() {
}

fn main() {
    let list = ArrayList::from_array<String>(["Yo", "I", "am", "in", "the", "list"]);
    list.iter()
        .map<String>(fn (item) {
            return item
        })
        .for_each(fn (item) {
            println(item) 
        });
